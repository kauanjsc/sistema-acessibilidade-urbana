# Configurações do Backend - Teresina Acessível

# Dica: Copia esse arquivo pra um .env e coloca as tuas credenciais.
# Não subir o .env pro GitHub, ele é só pra uso local. O .env.example é o modelo que a galera pode seguir.

# --- Banco de Dados ---
# Pega a URL do Transaction Pooler lá no Supabase (aquela da porta 6543)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# --- Autenticação (JWT) ---
# Pra gerar uma chave massa, roda aí: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Frontend & Segurança ---
# Coloca as URLs do front aqui pra não dar erro de CORS. 
# Se for subir pra Vercel dps, adiciona a URL dela separada por vírgula.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Configs Gerais ---
# Se for produção, muda o ENVIRONMENT pra 'production'
ENVIRONMENT=development
PORT=8000